          "views": null
        }
      ]
    },
    "fookid_62cf8a0908": {
      "text": "意外かもだけど、男は「いつでも会える女」ほど興味を失う生き物。",
      "structure_label": "男性心理断言型（属性×特性）",
      "first_used_at": "2026-06-07",
      "history": [
        {
          "scheduled_at": "2026-06-10T11:08:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        }
      ]
    },
    "fookid_2f96bc5705": {
      "text": "「彼との温度差が辛い」って悩んでる人の大半は、彼が冷たいんじゃなくて自分が熱量出しすぎてるだけ。",
      "structure_label": "常識否定型（〜じゃなくて自分の問題）",
      "first_used_at": "2026-06-07",
      "history": [
        {
          "scheduled_at": "2026-06-10T14:42:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        }
      ]
    },
    "fookid_47d53df59d": {
      "text": "男って、彼女に尽くされすぎると「やってあげる隙」がなくて気持ちが育たないんだよね。",
      "structure_label": "男性心理メカニズム型（隙＝彼の好意育成）",
      "first_used_at": "2026-06-07",
      "history": [
        {
          "scheduled_at": "2026-06-10T19:17:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        }
      ]
    },
    "fookid_f46cecaf23": {
      "text": "「彼から誘ってこない」って拗ねてる人の大半は、彼の興味が薄れたんじゃなくて自分から誘いすぎてるだけ。",
      "structure_label": "常識否定型（〜じゃなくて自分の問題）",
      "first_used_at": "2026-06-07",
      "history": [
        {
          "scheduled_at": "2026-06-10T19:52:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        }
      ]
    },
    "fookid_11643a1d60": {
      "text": "「重いって思われたくない」って我慢してる人の大半は、彼に嫌われるんじゃなくて自分の本音を出せてないだけ。",
      "structure_label": "常識否定型（〜じゃなくて自分の問題）",
      "first_used_at": "2026-06-07",
      "history": [
        {
          "scheduled_at": "2026-06-10T21:03:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        }
      ]
    },
    "fookid_e29d2af8a7": {
      "text": "「彼に尽くせば愛される」はウソ。",
      "structure_label": "常識否定型（俗説はウソ）",
      "first_used_at": "2026-06-07",
      "history": [
        {
          "scheduled_at": "2026-06-10T22:48:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        }
      ]
    },
    "fookid_f7971aa8c4": {
      "text": "男は、「予定全部合わせてくれる女性」と対等な関係を作れない。",
