    "fookid_c9c69565ed": {
      "text": "男は、「LINE5秒で返してくれる女性」と対等な関係を作れない。",
      "structure_label": "常識否定型（G-2-a派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-24T11:08:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_e0b79bfb52": {
      "text": "「もっと尽くせば溺愛される」って思ってるなら、一回止まってほしい。",
      "structure_label": "反転指摘型（F-3-c派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-24T14:42:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_e0405c826b": {
      "text": "「彼のLINEが素っ気ない」って感じてる人の大半は、彼が冷めたんじゃなくて自分が期待しすぎてるだけ。",
      "structure_label": "反転指摘型（F-8-b派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-24T19:17:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_1bf1b1cc16": {
      "text": "男が別れを切り出すとき「冷めた」より圧倒的に多いのが『一緒にいると息苦しい』。",
      "structure_label": "命題型（F-4-a）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-24T20:28:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_4c9a1aace4": {
      "text": "男は、「何でも察して先回りする女性」を女として見れない。",
      "structure_label": "常識否定型（G-2-a派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-24T21:03:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_fe3f3ed856": {
      "text": "男は、「自分の予定捨てて合わせてくれる女性」を本命にしない。",
      "structure_label": "常識否定型（G-2-a派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-25T11:08:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_2b8b75ef69": {
      "text": "「最近会えない」って感じてる人の大半は、彼が忙しいんじゃなくて自分が連絡しすぎてるだけ。",
      "structure_label": "反転指摘型（F-8-b派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-25T18:03:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_94512dc5e8": {
      "text": "男は、「先に予定埋めて待ってくれる女性」を本気で追わない。",
      "structure_label": "常識否定型（G-2-a派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-25T19:17:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_b170ab5803": {
      "text": "「いい彼女でいれば手放されない」って思ってるなら、一回止まってほしい。",
      "structure_label": "反転指摘型（F-3-c派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-25T19:52:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_94cc31a238": {
      "text": "男は、「尽くされてる＝大事にされてる」とは思っていない。",
      "structure_label": "命題型（G-1-a）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-25T20:28:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    }
  }
