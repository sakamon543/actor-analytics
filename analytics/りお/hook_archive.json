          "scheduled_at": "2026-06-17T20:28:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        },
        {
          "scheduled_at": "2026-06-18T22:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_e7303786d3": {
      "text": "男は、「連絡まめにくれる女性＝本命」とは思っていない。",
      "structure_label": "男性心理断言型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-11T18:03:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_21c34c07dc": {
      "text": "即レスして、LINEも10回推敲して、誕生日サプライズも2ヶ月前から準備してる人。残念だけど、その「尽くす」が彼の気持ちをどんどん遠ざけてるよ。",
      "structure_label": "行動描写警告型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-11T19:52:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_2ed2afce3e": {
      "text": "「重いって思われたくない」って我慢してる人の大半は、彼に嫌われたくないんじゃなくて自分を出すのが怖いだけ。",
      "structure_label": "常識否定×自分原因転換型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-11T22:17:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_9e5346807c": {
      "text": "「尽くせば男は離れない」はウソ。",
