      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T19:52:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_08c6a55e27": {
      "text": "「彼が私を見てくれない」って感じてる人の大半は、彼が冷めたんじゃなくて自分が頑張りすぎてるだけ。",
      "structure_label": "視点反転型",
      "first_used_at": "2026-06-16",
      "history": [
