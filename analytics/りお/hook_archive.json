          "scheduled_at": "2026-06-19T21:03:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_8448d6739d": {
      "text": "「便利な子」って言われたことない?それ、いつでも手に入る相手にされてるサインだよ。",
      "structure_label": "読者経験警告型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T22:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_af419ddb01": {
      "text": "男は、「何でもしてくれる女性」を本気で愛せない。",
