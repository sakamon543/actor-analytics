        },
        {
          "scheduled_at": "2026-06-19T19:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_2a551213d5": {
      "text": "「尽くす女は愛される」はウソ。",
      "structure_label": "常識破壊型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-17T19:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_051fa956df": {
      "text": "「彼が素っ気ない」って悩んでる人の大半は、彼が冷めたんじゃなくて自分の存在が当たり前になってるだけ。",
      "structure_label": "視点反転型",
