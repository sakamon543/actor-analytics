      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T19:52:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_a39522d446": {
      "text": "「ありがとう」だけの返事が増えてるなら、一回止まってほしい。彼が冷めたんじゃなくて、あなたが「いて当たり前」になってるだけ。",
      "structure_label": "常識否定×自分原因転換型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T21:03:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_4a4f882499": {
      "text": "男は、「何でも『いいよ』って言ってくれる女性」と対等な関係を作れない。",
      "structure_label": "男性心理断言型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T22:17:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_a5926fff63": {
      "text": "「サプライズすれば喜んでもらえる」って思ってる人の大半は、彼が喜んでないんじゃなくて自分が手間かけすぎてるだけ。",
      "structure_label": "常識否定×自分原因転換型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-13T11:08:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_fbfdd11896": {
      "text": "「私から動かないと進まない」って思ってるなら、一回止まってほしい。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-13T18:03:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_c43c48bb36": {
      "text": "「彼の予定に全部合わせれば愛される」って思ってる人の大半は、彼が冷めてるんじゃなくて自分の存在を安く見せてるだけ。",
      "structure_label": "常識否定×自分原因転換型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-13T20:28:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_0afa60cd3c": {
      "text": "「予定合わせるほど愛される」はウソ。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-13T21:03:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_ba07bd5945": {
      "text": "何でも「いいよ」「大丈夫」って言ってる人。優しさなんだけど、その「都合のいい女」ポジション、一度入ると本命に戻すのがすごく大変なんだよね。",
      "structure_label": "行動描写警告型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-13T22:48:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_de0748a4d9": {
      "text": "男は、「何でもしてくれる女性」を本気で愛せない",
      "structure_label": "男性心理断言型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-17T14:42:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_852395a3f1": {
      "text": "「お母さん」みたいって言われたことない?それ、最も危険なサインだよ。",
      "structure_label": "読者経験警告型",
      "first_used_at": "2026-06-16",
      "history": [
