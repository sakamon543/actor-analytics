    "fookid_19e350ada2": {
      "text": "ご飯作って、予定全部合わせて、LINEも5秒で既読つけて10回推敲して返してる人。残念だけど、その「尽くす」が彼の気持ちをどんどん遠ざけてるよ。",
      "structure_label": "行動描写警告型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T11:08:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_b50a405e7a": {
      "text": "「彼が忙しいから連絡控えてる」って思ってる人の大半は、彼が忙しいんじゃなくて自分が嫌われたくないだけ。",
      "structure_label": "常識否定×自分原因転換型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T13:17:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_e6d73eea83": {
      "text": "「予定全部合わせれば愛される」って思ってるなら、一回止まってほしい。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T19:17:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_a0e6b4101b": {
      "text": "男の「ありがとう」だけの返事は、冷めたサインじゃない。",
