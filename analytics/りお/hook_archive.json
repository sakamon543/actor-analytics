      "history": [
        {
          "scheduled_at": "2026-06-17T21:03:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_f0ecd32d9e": {
      "text": "「優しくしてあげれば男は喜ぶ」はウソ。",
      "structure_label": "常識破壊型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T11:08:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_7e0ba23fbb": {
      "text": "男は、「予定を合わせてくれる女性」を運命の相手とは思っていない",
      "structure_label": "男性心理断言型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T14:42:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_af9450f32c": {
      "text": "「妹みたい」って言われたことない?それ、彼の中であなたが「女」じゃなくなってる証拠だよ。",
      "structure_label": "読者経験警告型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T19:52:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_c4a80755f0": {
      "text": "「予定を合わせてあげる女は大事にされる」はウソ。",
      "structure_label": "常識破壊型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T21:03:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_7a353298ee": {
      "text": "男は、「何でも先回りしてくれる女性」を本気で追いかけられない",
      "structure_label": "男性心理断言型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T13:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_499d17bdc6": {
      "text": "「何でも合わせる女は愛される」って思ってるなら、一回止まってほしい。",
      "structure_label": "命題型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T18:03:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_560c89231a": {
      "text": "男は、「いつでも返信くれる女性」を追いかけられない",
