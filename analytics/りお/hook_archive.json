    "fookid_b8b66211bb": {
      "text": "彼の身の回りの世話、全部焼いてあげてる人。優しさなんだけど、その「お母さん」ポジション、一度入ると恋人に戻すのがすごく大変なんだよね。",
      "structure_label": "行動描写警告型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-11T14:42:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        },
        {
