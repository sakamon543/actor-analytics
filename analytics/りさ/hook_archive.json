          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_3e93074e74": {
      "text": "年上として、何を差し出せば年下が本気になるのか。答えは、大人の余裕でも若さでもありません。7歳下と2年目で確信した、本当に必要なのは、",
      "structure_label": "問いかけ命題型／否定列挙",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T18:03:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_19f7c8aef6": {
      "text": "年下男子の本音を言うと、頼られてる間は恋愛対象と見ない",
      "structure_label": "男性心理暴露型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T19:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_0bc5cccab7": {
      "text": "年下男子が「この人じゃなきゃ」と本気になる年上には、はっきりした共通点があります。若さでも、美貌でも、包容力でもありません。私が2年かけて掴んだ答えは、",
      "structure_label": "共通点発見型／常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T19:52:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_d946c532b2": {
      "text": "意外かもだけど、年下男子は『完璧な年上ほど手が出ない』生き物",
      "structure_label": "男性心理暴露型（生き物型）",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T21:03:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_dce42336c6": {
      "text": "経験談ですが、年上って「余裕を見せれば頼られる」と思い込んでいます",
      "structure_label": "経験者暴露型／思い込み暴き",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T22:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_0cfe0a59e4": {
      "text": "年下男子が「この人じゃなきゃ」って本気になる年上には、共通点があるんです。若さでも、完璧さでも、包容力でもない。むしろ逆で、",
      "structure_label": "共通点発見型／常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T11:08:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_288b7f22ca": {
      "text": "年下男子は、「頼れる年上=恋愛対象」とは思っていない",
      "structure_label": "心理否定型（等式否定）",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T14:42:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_333e79ae49": {
      "text": "年下男子の脈は、分かりやすいアプローチには出てきません。私も彼のサインを2年近く読み違えていました。本当に出るのは、こういうところです。",
      "structure_label": "反直感型／脈のサイン",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T18:03:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_89ad216839": {
      "text": "年下男子の「大人ですね」は褒め言葉じゃなくて、ただの『恋愛対象外通告』",
      "structure_label": "セリフの真意暴露型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T19:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_b4c266ab2e": {
      "text": "年下男子って興味ないから距離を取るんじゃなくて、憧れが強いほど動けなくなるんだよね",
