    "fookid_3f563b3fff": {
      "text": "好きな年下に、そろそろ気持ちを伝えようとしていませんか。それはまだ早いかもしれません。私も一度、勢いで伝えて、そこから2週間距離を置かれました。年下男子は、",
      "structure_label": "読者行動注意型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-25T11:08:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
