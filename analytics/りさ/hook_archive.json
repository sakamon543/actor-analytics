      ]
    },
    "fookid_93c2aba816": {
      "text": "7歳下と付き合って分かったんだけど、「余裕は逆効果」って話は本当",
      "structure_label": "経験者発見型／反転希望",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-25T13:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_81592dd6d5": {
      "text": "これ年上は恐らく知りませんが、年下男子は完璧な年上より隙のある年上に本気になる",
