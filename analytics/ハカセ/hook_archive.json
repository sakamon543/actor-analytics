    },
    "fookid_0234d919fa": {
      "text": "「完全に冷めた」って言われた絶望から、3週間で復縁した相談者がいるんだよね。",
      "structure_label": "反転希望型（絶望→希望）",
      "first_used_at": "2026-06-28",
      "history": [
        {
          "scheduled_at": "2026-06-30T19:17:00+09:00",
          "registered_at": "2026-06-28",
          "views": null
        }
      ]
    },
    "fookid_96c94b5431": {
      "text": "復縁した男に「LINEしなかったら戻ってきた？」って聞いたら、「絶対動かなかった」って即答だった。",
      "structure_label": "インタビュー対話引用型",
      "first_used_at": "2026-06-28",
      "history": [
        {
          "scheduled_at": "2026-06-30T20:28:00+09:00",
          "registered_at": "2026-06-28",
          "views": null
        }
      ]
    },
    "fookid_0f76021824": {
      "text": "「向こうから連絡くるはず」って信じて待ってる子。男は戻りたくても自分からは動けないんだよね。",
      "structure_label": "読者直接呼びかけ＋反転命題型",
      "first_used_at": "2026-06-28",
      "history": [
        {
          "scheduled_at": "2026-06-30T21:03:00+09:00",
          "registered_at": "2026-06-28",
          "views": null
        }
      ]
    },
    "fookid_788dcbbc8c": {
      "text": "「彼を変えれば復縁できる」って常識、220件のデータで真逆だったんだよね。",
      "structure_label": "常識反転型＋データ権威",
      "first_used_at": "2026-06-28",
      "history": [
        {
          "scheduled_at": "2026-06-30T22:17:00+09:00",
          "registered_at": "2026-06-28",
          "views": null
        }
      ]
    },
    "fookid_c8835c4a15": {
      "text": "男の本音を言うと、追われてる側は「うざい、早く離れて」しか考えてないんだよね。",
      "structure_label": "男性心理暴露型＋具体セリフ",
      "first_used_at": "2026-06-28",
      "history": [
        {
          "scheduled_at": "2026-07-01T11:08:00+09:00",
          "registered_at": "2026-06-28",
          "views": null
        }
      ]
    },
    "fookid_040c86ff3f": {
      "text": "「もう連絡来ない」って怯えてる子。振った男が「戻りたい」って動くまでの平均は55日だよ。",
      "structure_label": "反転希望型＋数字データ",
      "first_used_at": "2026-06-28",
      "history": [
        {
          "scheduled_at": "2026-07-01T13:17:00+09:00",
          "registered_at": "2026-06-28",
          "views": null
        }
      ]
    },
    "fookid_fad30b3071": {
      "text": "復縁失敗した相談者の多くが、最初の3週間で1つの行動を選んでた。",
      "structure_label": "失敗警告teaser型",
      "first_used_at": "2026-06-28",
      "history": [
        {
          "scheduled_at": "2026-07-01T14:42:00+09:00",
          "registered_at": "2026-06-28",
          "views": null
        }
      ]
    },
    "fookid_2456057051": {
      "text": "振った男が「戻りたい」って決意するまでの平均、220件で55日だったんだよね。",
      "structure_label": "数字データ断言型",
      "first_used_at": "2026-06-28",
      "history": [
        {
          "scheduled_at": "2026-07-01T19:17:00+09:00",
          "registered_at": "2026-06-28",
          "views": null
        }
      ]
    },
    "fookid_46791de37f": {
      "text": "元彼たちに直接聞いてきたけど、別れた後に共通して頭に浮かぶ言葉が1つあるんだよね。",
      "structure_label": "経験者の暴露型＋発見teaser",
      "first_used_at": "2026-06-28",
      "history": [
        {
          "scheduled_at": "2026-07-01T19:52:00+09:00",
          "registered_at": "2026-06-28",
          "views": null
        }
      ]
    },
    "fookid_ffde133ddf": {
      "text": "結論から伝える。復縁の正解は『3週間動かない』、これだけ。",
      "structure_label": "短文断言＋商品コア",
      "first_used_at": "2026-06-28",
      "history": [
        {
          "scheduled_at": "2026-07-01T20:28:00+09:00",
          "registered_at": "2026-06-28",
          "views": null
        }
      ]
    },
    "fookid_fdd76fcc70": {
      "text": "「もう戻ってこない」って絶望してる子。復縁した男たちに聞いたら全員『連絡なかったら動かなかった』だった。",
      "structure_label": "反転希望型＋対話引用",
      "first_used_at": "2026-06-28",
      "history": [
        {
          "scheduled_at": "2026-07-01T21:03:00+09:00",
          "registered_at": "2026-06-28",
          "views": null
        }
      ]
    }
  }
}