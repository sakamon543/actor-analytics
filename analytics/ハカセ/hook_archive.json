          "registered_at": "2026-06-11",
          "views": null
        }
      ]
    },
    "fookid_8ddba5aa43": {
      "text": "「黙ってれば彼から戻ってくる」って待ってる人。戻りたくてもプライドで言い出せないのが男なんだよね。",
      "structure_label": "男性心理暴露型",
