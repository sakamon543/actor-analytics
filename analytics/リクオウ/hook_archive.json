        },
        {
          "scheduled_at": "2026-06-27T22:17:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_02b4643555": {
      "text": "彼の「忙しい」に毎回「分かった、無理しないでね」って返してる女。",
      "structure_label": "観察・自分事指摘型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-17T21:03:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_92c98f64ee": {
      "text": "「彼の機嫌を取る」「彼の不満を消す」をやればやるほど、彼の中であなたの価値は薄れていく。",
      "structure_label": "反転メカニズム型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-17T22:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_bd8c962581": {
      "text": "尽くしてるのに彼が冷たいのは、愛情不足じゃない。むしろ彼が動く理由を全部先に潰してるだけだ。",
      "structure_label": "反転希望型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T11:08:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_fcac12e967": {
      "text": "男の本音を言うと、「私のこと好き?」を毎回確認してくる女は『追わなくても残る人』に確定してる。",
      "structure_label": "男性心理暴露型",
      "first_used_at": "2026-06-16",
      "history": [
