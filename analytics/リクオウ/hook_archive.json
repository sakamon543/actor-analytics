          "scheduled_at": "2026-06-23T11:08:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        },
        {
          "scheduled_at": "2026-06-24T11:08:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        },
        {
          "scheduled_at": "2026-06-25T13:17:00+09:00",
