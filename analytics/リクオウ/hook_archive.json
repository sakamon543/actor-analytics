      ]
    },
    "fookid_9c0b469084": {
      "text": "意外かもだけど、男は『俺の気持ちを全部分かってくれる女』にはむしろ努力しなくなる生き物。",
      "structure_label": "常識破壊系",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T14:42:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_9e18dd506e": {
      "text": "彼の予定を聞いてから、自分の予定をその場で空けてる女。",
      "structure_label": "観察・自分事指摘型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T18:03:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_8a24d6b13b": {
      "text": "「重く思われたくない」って我慢してる女ほど、彼にとっては『どうでもいい人』になっていく。",
      "structure_label": "観察・自分事指摘型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T11:08:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_1606dc3fcf": {
      "text": "男は『追わなくても返ってくる女』を本能で大事にできない。理由は、大事にしなくても勝手に残ってくれるから。",
      "structure_label": "男性本能メカニズム型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T13:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_96867378bf": {
      "text": "男って「いつでも会える女」と「予定を取りに行かないと会えない女」を、頭の中で別物に分けてる。",
      "structure_label": "男性脳分類暴露型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T14:42:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_9f0d8bf643": {
      "text": "デートで彼の好きなものに全部「私もそれ好き」って合わせてる女。",
      "structure_label": "観察・自分事指摘型",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T21:03:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        },
        {
          "scheduled_at": "2026-06-27T19:17:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_51aca82ae7": {
      "text": "意外かもだけど、男は『LINEに即レスしてくれる女』にはむしろ追いかける気が無くなる生き物。",
      "structure_label": "常識否定型（F-2-a）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-23T14:42:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_2353fbcb70": {
      "text": "デートで彼の好きなものに全部「私もそれ好き」って合わせてる女。それ、好かれてんじゃない。『何でも合わせてくれる楽な女』として記憶されてるだけだ。",
      "structure_label": "読者行動指摘＋再解釈型（F-7-a派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-23T18:03:00+09:00",
          "registered_at": "2026-06-22",
          "views": 1249,
          "posted_at": "2026-06-19T12:08:20.103+00:00"
        },
        {
          "scheduled_at": "2026-06-24T22:17:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        },
        {
          "scheduled_at": "2026-06-25T22:17:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_f24d21662e": {
      "text": "彼の話に全部「私もそれ好き！」って同調してる女。それ、好かれてんじゃない。『何でも合わせてくれる楽な女』として処理されてるだけだ。",
      "structure_label": "読者行動指摘＋再解釈型（F-7-a派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-23T19:52:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_20fcf0dd64": {
      "text": "男の素っ気ない返信は、あなたへの愛情が冷めたサインじゃない。",
      "structure_label": "常識否定型（F-7-a）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-23T21:03:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_8c6a6772cf": {
      "text": "「彼が好きだから尽くす」「彼のために何でもする」をやり続けるほど、彼の気持ちは離れていく。",
      "structure_label": "反転命題型（F-8-a派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-24T13:17:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_b789415491": {
      "text": "彼の「空いてる日」にいつも自分の予定を全部合わせてる女。彼にとってあなたは「いつ誘ってもOKな人」になってて、わざわざ予定を取りに行く価値がなくなってる。",
      "structure_label": "読者行動指摘＋再解釈型（F-7-a派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-24T14:42:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_6f6f7d9e4a": {
      "text": "彼の「忙しい時期」をいつも黙って待ってあげてる女。彼にとってあなたは「いつでも待ってくれる人」になってて、わざわざ時間を作る理由がなくなってる。",
      "structure_label": "読者行動指摘＋再解釈型（F-7-a派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-24T19:17:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_eae71cb16d": {
      "text": "意外かもだけど、男は『先回りして全部してくれる女』にはむしろ興味を失う生き物。",
      "structure_label": "常識否定型（F-2-a）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-24T20:28:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_4537fe8236": {
      "text": "男の本音を言うと、彼の機嫌を取りに行く女は「気を使わなくていい人」に勝手に分類してる。",
      "structure_label": "男性心理暴露型（B-3-a）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-25T11:08:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_04839b9dfb": {
      "text": "男の本音を言うと、自分のペースに全部合わせてくれる女は「動かなくていい人」に勝手に分類してる。",
      "structure_label": "男性心理暴露型（B-3-a）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-25T14:42:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_ad2a11cdbd": {
      "text": "尽くしてるのに彼が冷たいのは、あなたの愛情が足りないからじゃない。むしろ逆だ。",
      "structure_label": "反転希望型（F-7-a派生）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-25T18:03:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_c84029cc46": {
      "text": "男は、「尽くしてくれる女＝大事な存在」とは思っていない。",
      "structure_label": "男性心理断言型（G-1-a）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-25T19:17:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_d4e10d72e3": {
      "text": "意外かもだけど、男は『毎日「会いたい」って言ってくる女』にはむしろ追いかける気が無くなる生き物。",
      "structure_label": "常識否定型（F-2-a）",
      "first_used_at": "2026-06-22",
      "history": [
        {
          "scheduled_at": "2026-06-25T21:03:00+09:00",
          "registered_at": "2026-06-22",
          "views": null
        }
      ]
    },
    "fookid_16b0e34dee": {
      "text": "男の本音を言うと、即レスし続けてくれる女は「いつ返してもいい人」に勝手に分類してる。",
      "structure_label": "男性心理暴露型",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-26T13:17:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_0e78375db9": {
      "text": "「男は手間のかからない女が好き」はウソ。",
      "structure_label": "常識破壊型",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-26T19:17:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_b72fd0e24f": {
      "text": "LINEで彼の話題に全部「私もそう思う」って同意してる女。",
      "structure_label": "読者行動指摘型",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-26T19:52:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_09cde0a1c3": {
      "text": "返信が遅くて不安なのは、彼が冷めたからじゃない。",
      "structure_label": "反転希望型",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-26T22:17:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_d07a1f04eb": {
      "text": "男は『追わなくても返ってくる女』を本能で大事にできない。",
      "structure_label": "男性心理暴露型（命題）",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-27T11:08:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        },
        {
          "scheduled_at": "2026-06-28T21:03:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_19e9bdf14f": {
      "text": "彼の機嫌に合わせて自分のテンション上げ下げしてる女。",
      "structure_label": "読者行動指摘型",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-27T13:17:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_25a46b0694": {
      "text": "男の本音を言うと、文句一つ言わずに尽くしてくれる女は「気を使わなくていい人」に勝手に分類してる。",
      "structure_label": "男性心理暴露型",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-27T18:03:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_4241f09a8b": {
      "text": "男は「いつでも会える女」と本気で恋に落ちることはできない。",
      "structure_label": "男性心理暴露型（命題）",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-27T19:52:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_e5246bf8cf": {
      "text": "頑張ってるのに距離を感じるのは、あなたの努力が足りないからじゃない。",
      "structure_label": "反転希望型",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-27T21:03:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_83b7d0f250": {
      "text": "彼の返信時間に合わせてスマホ握りしめて待ってる女。",
      "structure_label": "読者行動指摘型",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-28T14:42:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_19cd3ef6f6": {
      "text": "男が距離を置くとき「冷めた」より圧倒的に多いのが『追わなくても繋がってる安心感』だよ。",
      "structure_label": "常識破壊型（〇〇より圧倒的に多いのが〇〇）",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-28T19:17:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_8b116039e2": {
      "text": "男の本音を言うと、こっちが冷たくしても変わらず優しい女は「雑に扱っていい人」に勝手に分類してる。",
      "structure_label": "男性心理暴露型",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-28T20:28:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    },
    "fookid_8dc329e21e": {
      "text": "愛してるって伝えれば伝えるほど彼との温度差が広がるのは、伝え方が悪いんじゃない。",
      "structure_label": "反転希望型（やればやるほど逆効果）",
      "first_used_at": "2026-06-25",
      "history": [
        {
          "scheduled_at": "2026-06-28T22:17:00+09:00",
          "registered_at": "2026-06-25",
          "views": null
        }
      ]
    }
  }
}