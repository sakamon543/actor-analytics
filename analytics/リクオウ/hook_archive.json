        },
        {
          "scheduled_at": "2026-06-10T19:17:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        },
        {
          "scheduled_at": "2026-06-17T19:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        },
        {
          "scheduled_at": "2026-06-18T22:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        },
        {
          "scheduled_at": "2026-06-19T20:28:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        },
        {
