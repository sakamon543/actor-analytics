{
  "hooks": {
    "fookid_4b92d1a4be": {
      "text": "マッチングアプリで一番時間を溶かすのは、ダラダラ保留している時間です。切りもしない、進めもしない。とりあえず月1で会っておく。私はそれを何人分も並行してやって、気づいたら2年が終わっていました🥲",
      "structure_label": "命題型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T11:08:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_7fb9852395": {
      "text": "同時進行を4人抱えている人は、全員に『どこか上の空』の顔で会っています。数をこなすほど、目の前の一人が景色に溶けていくだけです。",
      "structure_label": "命題型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T13:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_1bba32d859": {
      "text": "会う人数を減らすと、チャンスも減ると思っていませんか。逆でした。2年で47人と会って0人。絞ってからは3ヶ月で5人しか会っていません。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T14:42:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_6150ed20bd": {
      "text": "実は、真面目に『数をこなして比較しろ』を守った人ほど、3年経っても決まらないんです。比較しようとすると、頭の中で他の3人と並べる作業が始まって、目の前の一人が消えます。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T18:03:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_8a7b7e7d9b": {
      "text": "2回目に誘われる人と、誘われない人の差は、可愛さでも会話の上手さでもありません。「この子、ちゃんとこっち見てるな」と思われたかどうか。それだけでした。結婚してから旦那に聞いて、やっと分かりました🌷",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T19:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_7e955de65e": {
      "text": "男が2回目のデートを決めるとき『顔がタイプかどうか』より圧倒的に多いのが『この子、ちゃんと俺のこと見てるか』だそうです。旦那に聞いて、ようやく分かりました🌷",
      "structure_label": "男性心理暴露型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T19:52:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_b3ad76605d": {
      "text": "決めるなら、疲れる前です。疲れてから正しく選ぶことは、できないからです。私は2年と47人で、疲れ切る一歩手前まで行きました。29歳であの言葉をもらえたのは、運が良かっただけです🌷",
      "structure_label": "命題型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T20:28:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_d5b1953ef3": {
      "text": "『いい人だけどときめかない』の正体は、あなたの感度じゃないです。同時進行で心のスペースが埋まっていて、目の前の人にちゃんとハマれる余白が残っていないだけ。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T21:03:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_a8390058ed": {
      "text": "婚活3ヶ月で結婚が決まった人に共通してたのは、外見でも年齢でもなく『同時進行を4人以上抱えていなかった』ことです。3人までに絞れた瞬間から、会話の質が別物に変わります。",
      "structure_label": "命題型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-23T22:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_ecce99fe41": {
      "text": "『マッチングアプリは数を打て』は嘘です。数を追いかけて2年で47人会って0人だった私が、5人に絞った3ヶ月で結婚しました。数じゃなく、目の前の一人に熱量を戻すことです。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T11:08:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_2e29d8a05a": {
      "text": "意外かもだけど、男は『一生懸命プロフを盛った女性』より『目の前の自分をちゃんと見てる女性』を選ぶ生き物。だから、いいねを増やす努力は2回目に繋がらないんです。",
      "structure_label": "男性心理暴露型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T13:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_2fe9730352": {
      "text": "マッチングアプリで一番人生を溶かすのは、切りきれない人と月1で会い続ける時間です。進めるでも切るでもない、ただ抱えてる時間。私はそれを4人分並列で持って、2年が消えました🥲",
      "structure_label": "命題型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T14:42:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_ca295997ae": {
      "text": "『会う人数を増やせば当たる確率が上がる』って常識、嘘です。人数が増えるほど『とりあえず月1で会っておく』の相手が増えて、心のスペースが埋まっていくだけ。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T18:03:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_1a20feec04": {
      "text": "マッチングアプリで決まらない理由って『可愛くないから』とか『プロフが弱いから』みたいな理由じゃないの。同時進行で心が全員に『保留のまま』になってるのが、相手に全部バレてるだけです。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T19:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_e3b681b155": {
      "text": "『2回目に誘われない』のは、あなたの魅力が足りないからじゃないです。2時間ちゃんと目の前の人を見る余裕がないだけで、それは同時進行の人数を減らすだけで戻ります。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T19:52:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_16aad75eb9": {
      "text": "『疲れたら休めばいい』を繰り返してる限り、婚活は終わりません。休んで入れ直すたびに同じ4人同時進行を始めて、同じ場所で消耗して消す。それを3年続けてる人を何人も見てきました。",
      "structure_label": "失敗警告型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T20:28:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_76e65f426d": {
      "text": "結局、3ヶ月で結婚まで行けた人って『4人以上同時に会うのを捨てられた人』なんです。数を減らすと決めた瞬間から、会話の中で覚えていられる話題の量が別物になります。",
      "structure_label": "命題型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T21:03:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_42160690f4": {
      "text": "『土日が全部デートで埋まって疲れた』のに、通知が止まると不安でまたアプリを開いてしまう。この矛盾の正体は、あなたが弱いからじゃなくて同時進行の設計が壊れているからです。",
      "structure_label": "反転希望型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-24T22:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_c85144c0b5": {
      "text": "婚活して分かったんだけど、『疲れた人から結果が出なくなる』って話は本当。土日が全部埋まって『通知がめんどくさい』に変わった瞬間、目の前の一人にちゃんと会えなくなります。",
      "structure_label": "経験談型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-25T11:08:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_11c40cf61f": {
      "text": "実は、マッチングアプリで結婚に近い人ほど『同時進行の人数が少ない』んです。理由はシンプルで、心が分散していないから2時間ちゃんと目の前の人を見られるだけです。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-25T13:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_bd42706b0c": {
      "text": "2回目に呼ばれる人と、呼ばれない人の差は、写真の映えでもトーク力でもなかった。『この子、ちゃんとこっち見てるな』と思われたかどうか。それだけ。旦那に聞いて、それを知りました🌷",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-25T14:42:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_744c603e3b": {
      "text": "『いい人だけどときめかない』が2週続いたら、原因はあなたじゃなく同時進行の設計です。ときめけないんじゃなくて、心のスペースが埋まってて反応できる状態じゃないだけ。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-25T18:03:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_6087ca54c9": {
      "text": "私の経験上、3ヶ月で結婚が決まる女性って『同時に会うのは2人まで』のルールを守ってた人です。3人目を入れた瞬間から、頭の中は他人の予定表を組み立てる作業になります。",
      "structure_label": "経験談型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-25T19:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_ea8fcfc2de": {
      "text": "『いいねが来てもプロフィールを開かない日』がきたら要注意。あなたが贅沢になったんじゃなく、処理量が上限を超えて全部を『作業』で流してる状態です。本命候補も同じ扱いになります。",
      "structure_label": "失敗警告型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-25T19:52:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_78a2bc174d": {
      "text": "断言するけど、3ヶ月ダラダラ保留してる相手は、切っても結婚まで行きません。切って初めて、目の前の一人に熱量が戻る。切らないと、次の一人にも同じ雑さで会います。",
      "structure_label": "断言型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-25T20:28:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_c1befe734e": {
      "text": "『何人会ってもこの人だ！ってならない』のは、あなたの理想が高いからじゃないです。同時進行で全員に『保留の心』で会ってるから、誰にも刺さらないだけ。",
      "structure_label": "常識否定型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-25T21:03:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    },
    "fookid_cb8d73539d": {
      "text": "2時間のデート中ずっと『頭の中で他の男の予定を組み立ててる目』は男に全部バレます。旦那に『なんで俺だったの？』と聞いたら、そう言われました。同時進行を4人から2人に減らした翌週の会話です🌷",
      "structure_label": "男性心理暴露型",
      "first_used_at": "2026-07-22",
      "history": [
        {
          "scheduled_at": "2026-07-25T22:17:00+09:00",
          "registered_at": "2026-07-22",
          "views": null
        }
      ]
    }
  }
