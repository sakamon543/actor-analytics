          "views": null
        }
      ]
    },
    "fookid_efe25761c8": {
      "text": "別れた後、深夜に元彼のインスタ開いて、新しい投稿チェックして、いいね欄見て、新しい彼女のアカウント特定して比較してる人。",
      "structure_label": "読者行動描写型",
