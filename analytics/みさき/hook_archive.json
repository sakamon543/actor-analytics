          "views": null
        }
      ]
    },
    "fookid_e73561894a": {
      "text": "男が別れを決めるとき「冷めた」より圧倒的に多いのが『愛が大きくなりすぎてしんどい』なんだよね。",
      "structure_label": "男性心理暴露型（対比）",
      "first_used_at": "2026-06-04",
      "history": [
        {
          "scheduled_at": "2026-06-05T18:03:00+09:00",
          "registered_at": "2026-06-04",
          "views": null
        }
      ]
    },
    "fookid_a3b4493692": {
      "text": "別れて1週間目の彼と、1ヶ月後の彼は、別人だと思っていいよ。",
      "structure_label": "時系列対比型（命題）",
      "first_used_at": "2026-06-04",
      "history": [
        {
          "scheduled_at": "2026-06-05T19:17:00+09:00",
          "registered_at": "2026-06-04",
          "views": null
        }
      ]
    },
    "fookid_e75273cd30": {
      "text": "深夜に元彼のSNS見て、いいね欄チェックして、「また見ちゃった」って自己嫌悪で眠れない人。",
      "structure_label": "読者行動描写型",
      "first_used_at": "2026-06-04",
      "history": [
        {
          "scheduled_at": "2026-06-05T19:52:00+09:00",
