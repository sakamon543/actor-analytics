        },
        {
          "scheduled_at": "2026-06-10T21:03:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        },
        {
          "scheduled_at": "2026-06-10T22:48:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        },
        {
          "scheduled_at": "2026-06-11T21:03:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        },
        {
          "scheduled_at": "2026-06-13T22:48:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        },
        {
          "scheduled_at": "2026-06-17T18:03:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_cc49fcb2d8": {
      "text": "追いLINEを止めた瞬間に、男はやっと「あれ？」って気付く生き物。あなたが静かになった時間が、彼の中で一番響いてるんだよね。",
      "structure_label": "男心理逆説断言型",
      "first_used_at": "2026-06-07",
      "history": [
        {
          "scheduled_at": "2026-06-09T22:17:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        }
      ]
    },
    "fookid_41754fb827": {
      "text": "復縁して分かったんだけど、「未練が残るのは男」ってマジで本当だよ。",
      "structure_label": "経験者の暴露型（A-3）",
      "first_used_at": "2026-06-07",
      "history": [
        {
          "scheduled_at": "2026-06-09T22:48:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        }
      ]
    },
    "fookid_8887d69bf1": {
      "text": "別れた直後の冷たい彼と、3ヶ月後の彼は、本当に別人。今の彼の態度を「永遠」だと思い込まないで。",
      "structure_label": "時間軸対比型・命題型",
      "first_used_at": "2026-06-07",
      "history": [
        {
          "scheduled_at": "2026-06-10T14:42:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        }
      ]
    },
    "fookid_52906489e3": {
      "text": "深夜に元彼のSNS開いて、過去の投稿まで遡って、「また見ちゃった」って自己嫌悪で眠れない人。",
      "structure_label": "読者行動描写型",
      "first_used_at": "2026-06-07",
      "history": [
        {
          "scheduled_at": "2026-06-10T18:03:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        }
      ]
    },
    "fookid_988312ce01": {
      "text": "復縁した彼が言ってたんだけど、追われてる間は復縁を1ミリも考えなかったらしい。",
      "structure_label": "セリフ引用型（C-1）",
      "first_used_at": "2026-06-07",
      "history": [
        {
          "scheduled_at": "2026-06-10T19:17:00+09:00",
          "registered_at": "2026-06-07",
          "views": null
        }
      ]
    },
    "fookid_ecb839f42a": {
      "text": "「自分から連絡しないと何も変わらない」って思ってるなら、一回手を止めてほしい。",
      "structure_label": "読者直指し命題型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-11T13:17:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        },
        {
          "scheduled_at": "2026-06-12T11:08:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        },
        {
          "scheduled_at": "2026-06-13T20:28:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        },
        {
          "scheduled_at": "2026-06-17T14:42:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_a556d02b8c": {
      "text": "別れて1週間の彼と、1ヶ月後の彼は、別人だと思った方がいい。",
      "structure_label": "命題型（時系列対比）",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-11T18:03:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_1a7ad41f0e": {
      "text": "男が別れを決めるとき「冷めた」より圧倒的に多いのが『愛が強くなりすぎた』なんだよね。",
      "structure_label": "常識否定型（対比）",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-11T19:52:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_fb305b7b5e": {
      "text": "別れた直後の彼と、半年経った彼は、別人だと思った方がいい。",
      "structure_label": "命題型（時系列対比）",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-11T20:28:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_e1a18c76b5": {
      "text": "「連絡しなきゃ彼に忘れられる」って思ってるなら、その焦り全部逆効果だよ。",
      "structure_label": "読者直指し命題型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-11T22:17:00+09:00",
          "registered_at": "2026-06-10",
          "views": 137,
          "posted_at": "2026-06-11T13:22:13.362+00:00"
        },
        {
          "scheduled_at": "2026-06-17T21:03:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        },
        {
          "scheduled_at": "2026-06-19T19:52:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_05dceb8731": {
      "text": "復縁して分かったんだけど、「未練が残るのは男」って話は本当だった。",
      "structure_label": "経験者暴露型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T13:17:00+09:00",
          "registered_at": "2026-06-10",
          "views": 2,
          "posted_at": "2026-06-12T04:21:34.797+00:00"
        }
      ]
    },
    "fookid_e90ee93cd5": {
      "text": "寝る前に元彼のストーリー覗いて、新しい彼女のアカ見て泣いてる人。",
      "structure_label": "読者行動描写型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T14:42:00+09:00",
          "registered_at": "2026-06-10",
          "views": 2,
          "posted_at": "2026-06-12T05:46:07.652+00:00"
        }
      ]
    },
    "fookid_9f35ef854c": {
      "text": "別れた後に新しい彼女のアカウント特定して、毎日比較してる人。",
      "structure_label": "読者行動描写型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T19:17:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_219af3800f": {
      "text": "男は、「連絡が続いている＝気持ちがある」とは思っていない。",
      "structure_label": "男心理断言型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T19:52:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_5c66f070d7": {
      "text": "男って追われてる間は、復縁を1ミリも考えないんだよね。",
      "structure_label": "男心理暴露型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T21:03:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_2f7961b102": {
      "text": "男って沈黙してる時、嫌いになったから黙ってるんじゃないんだよね。",
      "structure_label": "常識否定型（現象解釈）",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-12T22:48:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_7788294b7d": {
      "text": "元彼が連絡しようか迷うときって、結局『忘れようとすればするほど思い出す』って気づいたときなんだよね。",
      "structure_label": "男心理暴露型（衝撃命題）",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-13T13:17:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_4b4070125f": {
      "text": "元彼のインスタを朝晩チェックして、新しい投稿があるたび一喜一憂してる人。",
      "structure_label": "読者行動描写型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-13T14:42:00+09:00",
          "registered_at": "2026-06-10",
          "views": 2,
          "posted_at": "2026-06-13T05:46:17.128+00:00"
        }
      ]
    },
    "fookid_1e45530754": {
      "text": "「自分から動かなきゃ何も始まらない」って思ってるなら、その手を一回止めて。",
      "structure_label": "読者直指し命題型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-13T19:17:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_bed0bd52c8": {
      "text": "男性は1度冷めても惚れ直すから、復縁を目指す女性は諦めなくていいよ。",
      "structure_label": "反転希望型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-13T19:52:00+09:00",
          "registered_at": "2026-06-10",
          "views": 3,
          "posted_at": "2026-06-13T10:57:01.219+00:00"
        }
      ]
    },
    "fookid_659c9acffc": {
      "text": "深夜にインスタ開いて、彼のいいね欄チェックして、自己嫌悪で寝れない人。",
      "structure_label": "読者行動描写型",
      "first_used_at": "2026-06-10",
      "history": [
        {
          "scheduled_at": "2026-06-13T21:03:00+09:00",
          "registered_at": "2026-06-10",
          "views": null
        }
      ]
    },
    "fookid_d9a6a3acd0": {
      "text": "朝起きて、寝る前に、必ず元彼のストーリーチェックしてる人。それやめないと前に進めないよ。",
      "structure_label": "reader_now型・行動指摘",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-17T19:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_ae9feb842e": {
      "text": "気づいたら元彼の名前検索して、新しい投稿ないか確認してる人。そのループ抜けないと、彼の中であなたは『重い元カノ』のままだよ。",
      "structure_label": "reader_now型・行動指摘",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-17T20:28:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_3e91854576": {
      "text": "別れて3日目の彼と、3ヶ月目の彼は、別人だと思った方がいい。3日目はまだ「あの時の怒り」が生々しくて、こっちが何送っても悪い方にしか取られない時期。",
      "structure_label": "時系列対比型・常識否定",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T11:08:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_2cdff7bc19": {
      "text": "「LINE送らなきゃ気持ち伝わらない」って思ってるなら、その焦り全部逆効果だよ。",
      "structure_label": "通念否定→反転希望",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T13:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_3bd1e8f9ff": {
      "text": "別れて1週間目の彼と、3ヶ月目の彼は、別人だと思った方がいい。",
      "structure_label": "時系列対比型・常識否定",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T14:42:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_93df0abb85": {
      "text": "「私から動かないと何も始まらない」って思ってるなら、一回手を止めてほしい。",
      "structure_label": "通念否定→反転希望",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T18:03:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_0215f3b7d4": {
      "text": "別れて2週間目の彼と、4ヶ月目の彼は、別人だと思った方が動きやすいよ。",
      "structure_label": "時系列対比型・常識否定",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T19:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": 1756,
          "posted_at": "2026-06-18T10:21:47.84+00:00"
        }
      ]
    },
    "fookid_d459968072": {
      "text": "「沈黙してたら彼に完全に忘れられる」って思ってる人。実は逆で、追わなくなった瞬間から彼の中で記憶が動き出すよ。",
      "structure_label": "通念否定→反転希望",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T20:28:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_b88bf92bc7": {
      "text": "既読つかないLINEを何度も開いて確認してる人。回数増やしても彼の見方は変わらないよ。",
      "structure_label": "reader_now型・行動指摘",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-18T22:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_1dd6b5ab94": {
      "text": "別れて1ヶ月の彼と、半年経った彼は、別人だと思った方がいい。",
      "structure_label": "時系列対比型・常識否定",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T13:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_20593d3a3f": {
      "text": "LINEの返信頻度で彼の気持ちを測ってる人。男は『連絡の量＝好きの量』で考えてないよ。",
      "structure_label": "reader_now型・男性心理暴露",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T18:03:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_6e59bdabc2": {
      "text": "別れて5日目の彼と、半年後の彼は、別人だと思った方がいい。",
      "structure_label": "時系列対比型・常識否定",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T19:17:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    },
    "fookid_46c1b11c97": {
      "text": "別れた彼の沈黙を『もう完全に終わり』のサインだって受け取ってる人。それ、男の中では全然違う意味だよ。",
      "structure_label": "reader_now型・男性心理暴露",
      "first_used_at": "2026-06-16",
      "history": [
        {
          "scheduled_at": "2026-06-19T20:28:00+09:00",
          "registered_at": "2026-06-16",
          "views": null
        }
      ]
    }
  }
}